APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=null
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Trust reverse proxies (comma-separated IPs or "*")
TRUSTED_PROXIES=*

# Force HTTPS (also configurable in system settings)
FORCE_HTTPS=false
FORCE_HTTPS_IN_LOCAL=false

# Security headers (defaults used when not set in DB)
SECURITY_ENABLE_HSTS=true
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=false
SECURITY_CSP=
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
SECURITY_PERMISSIONS_POLICY="geolocation=(), microphone=(), camera=(self)"

# SMS (Beem Africa) — https://beem.africa
BEEM_API_KEY=
BEEM_SECRET_KEY=
BEEM_SENDER_ID=SAFCO
BEEM_SMS_URL=https://apisms.beem.africa/v1/send
# Legacy aliases (optional)
SMS_KEY=
SMS_TOKEN=
SMS_SENDERID=
SMS_URL=

# Lipisha payments (overridable via system settings)
LIPISHA_ENABLED=false
LIPISHA_BUSINESS_ID=
LIPISHA_BUSINESS_NAME=
LIPISHA_BUSINESS_KEY=
LIPISHA_VERIFY_TOKEN=

# ESC/POS receipt printer device path
ESCPOS_DEVICE=/dev/usb/lp1

# Optional: Postmark / Resend / Slack (see config/services.php)
POSTMARK_TOKEN=
RESEND_KEY=
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=

# hotel-portal (Next.js): use hotel-portal/.env.local — NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api
